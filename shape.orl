namespace ori.game.shape

import ori.math.vec2 as vec2

public struct Rectangle
    x: float
    y: float
    width: float
    height: float
end

public struct Circle
    x: float
    y: float
    radius: float
end

public struct Triangle
    x1: float
    y1: float
    x2: float
    y2: float
    x3: float
    y3: float
end

public struct Line
    x1: float
    y1: float
    x2: float
    y2: float
end

public struct Polygon
    points: list<vec2.Vec2>
end
